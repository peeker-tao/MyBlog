<aside class="sidebar">
  <div class="card">
    <h3>搜索</h3>
    <form class="search-form" action="/search" method="get">
      <input type="text" name="q" placeholder="搜索文章" />
      <button type="submit">搜索</button>
    </form>
  </div>

  <div class="card" style="margin-top: 18px;">
    <h3>近期文章</h3>
    <% if (recentPosts && recentPosts.length) { %>
      <ul class="recent-list">
        <% recentPosts.forEach((p) => { %>
          <li><a href="/post/<%= p.slug %>"><%= p.title %></a></li>
        <% }) %>
      </ul>
    <% } else { %>
      <div class="meta">暂无文章。</div>
    <% } %>
  </div>

  <div class="card" style="margin-top: 18px;">
    <h3>分类</h3>
    <% if (categories && categories.length) { %>
      <div class="tag-cloud">
        <% categories.forEach((category) => { %>
          <a class="tag" href="/category/<%= category.slug %>"><%= category.name %> (<%= category.post_count %>)</a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="meta">还没有分类。</div>
    <% } %>
  </div>

  <div class="card" style="margin-top: 18px;">
    <h3>标签</h3>
    <% if (tags && tags.length) { %>
      <div class="tag-cloud">
        <% tags.forEach((tag) => { %>
          <a class="tag" href="/tag/<%= tag.slug %>"><%= tag.name %> (<%= tag.post_count %>)</a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="meta">还没有标签。</div>
    <% } %>
  </div>
</aside>
